            "body": [
              {
                "t": "p",
                "c": [
                  {
                    "t": "txt",
                    "v": "Tested by our editorial team across GPT-4o and Claude 3.5 in supervised clinical settings:"
                  }
                ]
              },
              {
                "t": "ul",
                "items": [
                  {
                    "t": "p",
                    "c": [
                      {
                        "t": "b",
                        "c": [
                          {
                            "t": "txt",
                            "v": "Discharge Summary: "
                          }
                        ]
                      },
                      {
                        "t": "txt",
                        "v": "\"Summarize this admission for [dx]. Include: 1-line summary, key decisions, pending results, and 3 follow-up actions for the outpatient team.\""
                      }
                    ]
                  },
                  {
                    "t": "p",
                    "c": [
                      {
                        "t": "b",
                        "c": [
                          {
                            "t": "txt",
                            "v": "Literature DDx: "
                          }
                        ]
                      },
                      {
                        "t": "txt",
                        "v": "\"Summarize current evidence for [treatment] in [condition], highlight level of evidence, and flag ongoing phase 3 trials.\""
                      }
                    ]
                  },
                  {
                    "t": "p",
                    "c": [
                      {
                        "t": "b",
                        "c": [
                          {
                            "t": "txt",
                            "v": "DDx Builder: "
                          }
                        ]
                      },
                      {
                        "t": "txt",
                        "v": "\"Generate a differential for a 42yo with [symptoms]. Rank by likelihood, list one distinguishing feature per diagnosis.\""
                      }
                    ]
                  }
                ]
              }
            ],
